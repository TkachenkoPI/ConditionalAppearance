			.КонецГруппы()
			.Оформление("ЦветФона", WebЦвета.Золотой);
	
	Результат = "Обработки.УсловноеОформление.СоздатьОбъект(УсловноеОформление)
	|	.Очистить()
	|	.Элемент(Элементы.Реквизит2)
	|		.ГруппаИ()
	|			.Равно(Элементы.Реквизит2, 0)
	|			.НеРавно(Элементы.Реквизит3, Истина)
	|			.ГруппаИли()
	|				.Равно(Элементы.Реквизит4, Истина)
	|				.НачинаетсяС(Элементы.Реквизит1, ""я"")
	|			.КонецГруппы()
	|		.КонецГруппы()
	|		.Оформление(""ЦветФона"", WebЦвета.Золотой);";
	

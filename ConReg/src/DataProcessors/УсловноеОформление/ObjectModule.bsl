#Область СлужебныеПроцедурыИФункции

// Установить.
// 
// Параметры:
//  НовоеУсловноеОформление - УсловноеОформлениеКомпоновкиДанных
Процедура Установить(НовоеУсловноеОформление) Экспорт

	УсловноеОформление = НовоеУсловноеОформление;

КонецПроцедуры

Процедура ПодготовкаПолейКомпоновкиДанных(Элемент, Тип, Объект)

	Если Тип = Тип("Строка") Тогда
		Массив = СтрРазделить(Объект, ", ", Ложь);

		Для Каждого Имя Из Массив Цикл
			ДобавитьПолеКомпоновкиДанных(Элемент, Имя);
		КонецЦикла;

	Иначе
		СтруктураПроверки = Новый Структура("Имя", "");
		ЗаполнитьЗначенияСвойств(СтруктураПроверки, Объект);

		Если ЗначениеЗаполнено(СтруктураПроверки.Имя) Тогда
			ДобавитьПолеКомпоновкиДанных(Элемент, СтруктураПроверки.Имя);
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

Процедура ДобавитьПолеКомпоновкиДанных(Элемент, Имя)

	ОформляемоеПоле = Элемент.Поля.Элементы.Добавить();
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных(Имя);

КонецПроцедуры

Процедура ПроверкаЭлемента()

	Если ТекущийЭлемент = Неопределено Тогда
		ВызватьИсключение НСтр("Сначала вызовите метод ""Элемент""");
	КонецЕсли;

КонецПроцедуры

Функция Табуляция(Раз)

	Результат = "";

	Для Счетчик = 1 По Раз Цикл
		Результат = Результат + Символы.Таб;
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ВернутьЗначениеДляОформления(Значение)

	Результат = "";
	ТипЗначения = ТипЗнч(Значение);

	// ToDo: Другие вариации условий

	Если ТипЗначения = Тип("Цвет") Тогда

		Если Значение.Вид = ВидЦвета.WebЦвет Тогда
			Значение = Строка(Значение);

			НачалоАнглийского = СтрНайти(Значение, "(");

			Если НачалоАнглийского <> 0 Тогда
				Значение = Сред(Значение, 1, НачалоАнглийского - 1);
			КонецЕсли;

			Результат = СтрШаблон("WebЦвета[""%1""]", СтрЗаменить(Значение, " ", ""));
		КонецЕсли;
	
	ИначеЕсли ТипЗначения = Тип("ГоризонтальноеПоложение") Тогда
		Результат = ЗначениеГоризонтальногоПоложения(Значение);
	КонецЕсли;

	Возврат Результат;

КонецФункции

Процедура РазобратьОтбор(Результат, Отбор, Табуляция)

	Для Каждого ЭлементОтбора Из Отбор.Элементы Цикл

		Если ТипЗнч(ЭлементОтбора) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда

			Если ЭлементОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ Тогда
				ПредставлениеГруппы = "ГруппаИ";
			ИначеЕсли ЭлементОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли Тогда
				ПредставлениеГруппы = "ГруппаИли";
			Иначе // ГруппаНе
				ПредставлениеГруппы = "ГруппаНе";
			КонецЕсли;

			Результат = Результат + СтрШаблон(ШаблонГруппы(Табуляция), ПредставлениеГруппы);

			РазобратьОтбор(Результат, ЭлементОтбора, Табуляция + 1);

			Результат = Результат + СтрШаблон(ШаблонКонцаГруппы(Табуляция));
		ИначеЕсли ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
			ШаблонЭлементаОтбора = ШаблонЭлементаОтбора(Табуляция + 1);

			Результат = Результат + СтрШаблон(ШаблонЭлементаОтбора, ПредставлениеВидаСравнения(
				ЭлементОтбора.ВидСравнения), Строка(ЭлементОтбора.ЛевоеЗначение), ЗначениеОтбора(
				ЭлементОтбора.ПравоеЗначение));
		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

Функция ПредставлениеВидаСравнения(ВидСравнения)

	Возврат СтрЗаменить(ТРег(Строка(ВидСравнения)), " ", "");

КонецФункции

Функция ЗначениеОтбора(Значение)

	Возврат "_ПодставтеЗначение_";

КонецФункции

Функция ШаблонГруппы(Табуляция)

	Возврат Символы.ПС + Табуляция(Табуляция) + ".%1()";

КонецФункции

Функция ШаблонЭлементаОтбора(Табуляция)

	Возврат Символы.ПС + Табуляция(Табуляция) + ".%1(""%2"", %3)";

КонецФункции

Функция ШаблонКонцаГруппы(Табуляция)

	Возврат Символы.ПС + Табуляция(Табуляция) + ".КонецГруппы()";

КонецФункции

Процедура ДобавитьГруппу(ТипГруппы)

	ПроверкаЭлемента();

	Если ТипЗнч(ТекущийЭлемент) = Тип("ЭлементУсловногоОформленияКомпоновкиДанных") Тогда
		ГруппаОтбора = ТекущийЭлемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	Иначе // ГруппаЭлементовОтбораКомпоновкиДанных
		ГруппаОтбора = ТекущийЭлемент.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	КонецЕсли;

	ГруппаОтбора.ТипГруппы = ТипГруппы;

	ТекущийЭлемент = ГруппаОтбора;

КонецПроцедуры

Функция ЗначениеГоризонтальногоПоложения(Значение)
	
	Соответствие = Новый Соответствие;
	
	Соответствие.Вставить(ГоризонтальноеПоложение.Авто, "ГоризонтальноеПоложение.Авто");
	Соответствие.Вставить(ГоризонтальноеПоложение.Лево, "ГоризонтальноеПоложение.Лево");
	Соответствие.Вставить(ГоризонтальноеПоложение.ПоШирине, "ГоризонтальноеПоложение.ПоШирине");
	Соответствие.Вставить(ГоризонтальноеПоложение.Право, "ГоризонтальноеПоложение.Право");
	Соответствие.Вставить(ГоризонтальноеПоложение.Центр, "ГоризонтальноеПоложение.Центр");
	
	Возврат Соответствие.Получить(Значение);
	
КонецФункции

#КонецОбласти
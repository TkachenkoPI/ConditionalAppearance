	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(Поле);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.НеПодобно;
	ОтборЭлемента.ПравоеЗначение = Значение;

	Возврат ЭтотОбъект;

КонецФункции


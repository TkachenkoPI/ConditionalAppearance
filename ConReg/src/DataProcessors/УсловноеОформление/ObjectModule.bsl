Процедура Установить(НовоеУсловноеОформление) Экспорт

	УсловноеОформление = НовоеУсловноеОформление;

КонецПроцедуры

Процедура ПроверкаЭлемента()

	Если ТекущийЭлемент = Неопределено Тогда
		ВызватьИсключение НСтр("Сначала вызовите метод ""Элемент""");
	КонецЕсли;

КонецПроцедуры

Функция Табуляция(Раз)

	Результат = "";

	Для Счетчик = 1 По Раз Цикл
		Результат = Результат + Символы.Таб;
	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ВернутьЗначениеДляОформления(Значение)

	Результат = "";
	ТипЗначения = ТипЗнч(Значение);

	// ToDo: Другие вариации условий
	
	Если ТипЗначения = Тип("Цвет") Тогда

		Если Значение.Вид = ВидЦвета.WebЦвет Тогда
			Значение = Строка(Значение);

			НачалоАнглийского = СтрНайти(Значение, "(");

			Если НачалоАнглийского <> 0 Тогда
				Значение = Сред(Значение, 1, НачалоАнглийского - 1);
			КонецЕсли;

			Результат = СтрШаблон("WebЦвета[%1]", СтрЗаменить(Значение, " ", ""));
		КонецЕсли;

	КонецЕсли;

	Возврат Результат;

КонецФункции

#КонецОбласти
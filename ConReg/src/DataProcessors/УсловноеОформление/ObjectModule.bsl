#Область ОписаниеПеременных

Перем УсловноеОформление;
Перем Элемент;
Перем ГруппаОтбора;
Перем ТекущийЭлемент;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Элемент.
// 
// Параметры:
//  Имя - Строка - Имя
// 
// Возвращаемое значение:
//  ОбработкаОбъект.УсловноеОформление - Элемент
Функция Элемент(Имя = "") Экспорт

	Если Не ЗначениеЗаполнено(Имя) Тогда
		Имя = XMLСтрока(Новый УникальныйИдентификатор);
	КонецЕсли;

	Элемент = УсловноеОформление.Элементы.Добавить();
	ТекущийЭлемент = Элемент;

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Имя);

	Возврат ЭтотОбъект;

КонецФункции

Функция Очистить() Экспорт

	УсловноеОформление.Элементы.Очистить();

	Возврат ЭтотОбъект;

КонецФункции

// Оформление.
// 
// Параметры:
//  Свойство - Строка - "ОтметкаНезаполненного", 
//  Значение - Произвольный - 
// 
// Возвращаемое значение:
//  ОбработкаОбъект.УсловноеОформление - Оформление
Функция Оформление(Свойство, Значение) Экспорт

	ПроверкаЭлемента();

	Элемент.Оформление.УстановитьЗначениеПараметра(Свойство, Значение);

	Возврат ЭтотОбъект;

КонецФункции

// Генерирует код, который можно копипасть к себе на основании передоного в объект условного  офрмелния
// 
// Возвращаемое значение:
//  Строка - готовый код
Функция СгенерироватьКод() Экспорт

	Результат = "Обработки.УсловноеОформление.СоздатьОбъект(УсловноеОформление)";

	ШаблонОформления = Символы.ПС + Табуляция(3) + ".Оформление(""%1"", %2)";

	Для Каждого Элемент Из УсловноеОформление.Элементы Цикл

		Если Не Элемент.Использование Тогда
			Продолжить;
		КонецЕсли;
		
		// ToDo: Группы
		
		// ToDo: Отборы

		Для Каждого Оформление Из Элемент.Оформление.Элементы Цикл

			Если Не Оформление.Использование Тогда
				Продолжить;
			КонецЕсли;

			Результат = Результат + СтрШаблон(ШаблонОформления, Строка(Оформление.Параметр),
				ВернутьЗначениеДляОформления(Оформление.Значение));
		КонецЦикла;

	КонецЦикла;

	Возврат Результат;

КонецФункции

#Область Группы

Функция ГруппаИ() Экспорт

	ПроверкаЭлемента();

	ГруппаОтбора = ТекущийЭлемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;

	ТекущийЭлемент = ГруппаОтбора;

	Возврат ЭтотОбъект;

КонецФункции


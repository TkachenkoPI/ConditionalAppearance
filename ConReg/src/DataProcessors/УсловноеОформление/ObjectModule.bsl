#Область ПрограммныйИнтерфейс

// Элемент/ы к которым будет применено условное оформление.
// 
// Параметры:
//  Имена - Строка - Имя элемента для которого применяем значение. 
//                 Можно передать множество элементов, разделив ", ".
//  	- ТаблицаФормы, ПолеФормы, ГруппаФормы - Объект должен содержать свойство "Имя"
//      - Массив Из Строка - 
//      - Массив Из ТаблицаФормы, ПолеФормы, ГруппаФормы -
// 
// Возвращаемое значение:
//  ОбработкаОбъект.УсловноеОформление - Элемент
Функция Элемент(Имена) Экспорт

	Элемент = УсловноеОформление.Элементы.Добавить();
	ТекущийЭлемент = Элемент;

	Тип = ТипЗнч(Имена);

	Если Тип = Тип("Массив") Тогда

		Для Каждого Имя Из Имена Цикл
			Тип = ТипЗнч(Имя);
			ПодготовкаПолейКомпоновкиДанных(Элемент, Тип, Имя);
		КонецЦикла;

	Иначе
		ПодготовкаПолейКомпоновкиДанных(Элемент, Тип, Имена);
	КонецЕсли;

	Возврат ЭтотОбъект;

КонецФункции

// Очищает условное оформление.
// 
// Возвращаемое значение:
//  ОбработкаОбъект.УсловноеОформление - Очистить
Функция Очистить() Экспорт

	УсловноеОформление.Элементы.Очистить();

	Возврат ЭтотОбъект;

КонецФункции

// Оформление.
// 
// Параметры:
//  Свойство - Строка - "ОтметкаНезаполненного", 
//  Значение - Произвольный - 
// 
// Возвращаемое значение:
//  ОбработкаОбъект.УсловноеОформление - Оформление
Функция Оформление(Свойство, Значение) Экспорт

	ПроверкаЭлемента();

	Элемент.Оформление.УстановитьЗначениеПараметра(Свойство, Значение);

	Возврат ЭтотОбъект;

КонецФункции

// Генерирует код, который можно копипасть к себе на основании передоного в объект условного  офрмелния
// 
// Возвращаемое значение:
//  Строка - готовый код
Функция СгенерироватьКод() Экспорт

	Результат = "Обработки.УсловноеОформление.СоздатьОбъект(УсловноеОформление)";

	БазоваяТабуляция = 1;

	Результат = Результат + Символы.ПС + Табуляция(БазоваяТабуляция) + ".Очистить()";

	ШаблонЭлемента = Символы.ПС + Табуляция(БазоваяТабуляция) + ".Элемент(""%1"")";
	ШаблонОформления = Символы.ПС + Табуляция(БазоваяТабуляция + 1) + ".Оформление(""%1"", %2)";

	Для Каждого Элемент Из УсловноеОформление.Элементы Цикл

		Если Не Элемент.Использование Тогда
			Продолжить;
		КонецЕсли;

		Результат = Результат + СтрШаблон(ШаблонЭлемента, Строка(Элемент.Поля));

		РазобратьОтбор(Результат, Элемент.Отбор, БазоваяТабуляция + 1);

		Для Каждого Оформление Из Элемент.Оформление.Элементы Цикл

			Если Не Оформление.Использование Тогда
				Продолжить;
			КонецЕсли;

			Результат = Результат + СтрШаблон(ШаблонОформления, Строка(Оформление.Параметр),
				ВернутьЗначениеДляОформления(Оформление.Значение));
		КонецЦикла;

	КонецЦикла;

	Возврат Результат + ";";

КонецФункции


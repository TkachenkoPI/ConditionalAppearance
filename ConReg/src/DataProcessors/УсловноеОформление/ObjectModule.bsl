Функция КонецГруппы() Экспорт

	ПроверкаЭлемента();

	Если ТекущийЭлемент.Родитель <> Неопределено Тогда
		ТекущийЭлемент = ТекущийЭлемент.Родитель;
	КонецЕсли;

	Возврат ЭтотОбъект;

КонецФункции


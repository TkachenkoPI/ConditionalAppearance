Функция ДобавитьОтбор(Поле, ВидСравнения, Значение)

	ОтборЭлемента = КонтейнерОтбора().Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(АдаптерПоля(Поле));
	ОтборЭлемента.ВидСравнения = ВидСравнения;
	ОтборЭлемента.ПравоеЗначение = Значение;

	Возврат ЭтотОбъект;

КонецФункции

Процедура ДобавитьГруппу(ТипГруппы)

	ГруппаОтбора = КонтейнерОтбора().Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаОтбора.ТипГруппы = ТипГруппы;

	ТекущийЭлемент = ГруппаОтбора;

КонецПроцедуры

// Коллекция, в которую добавляются отборы и группы отборов.
// Если группа не открыта - это отбор самого элемента условного оформления.
//
// Возвращаемое значение:
//  ОтборКомпоновкиДанных, ГруппаЭлементовОтбораКомпоновкиДанных - контейнер отбора
Функция КонтейнерОтбора()

	ПроверкаЭлемента();

	Если ТипЗнч(ТекущийЭлемент) = Тип("ЭлементУсловногоОформленияКомпоновкиДанных") Тогда
		Возврат ТекущийЭлемент.Отбор;
	КонецЕсли;

	Возврат ТекущийЭлемент;

КонецФункции

Процедура ДобавитьОформляемоеПоле(Источник)

	Если ТипЗнч(Источник) = Тип("Строка") Тогда

		Для Каждого ЧастьИмени Из СтрРазделить(Источник, ",", Ложь) Цикл

			Имя = СокрЛП(ЧастьИмени);

			Если ЗначениеЗаполнено(Имя) Тогда
				ДобавитьПолеКомпоновкиДанных(Имя);
			КонецЕсли;

		КонецЦикла;

		Возврат;
	КонецЕсли;

	ДобавитьПолеКомпоновкиДанных(ИмяЭлементаФормы(Источник));

КонецПроцедуры

Процедура ДобавитьПолеКомпоновкиДанных(Имя)

	ОформляемоеПоле = ОформляемыйЭлемент.Поля.Элементы.Добавить();
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных(Имя);

КонецПроцедуры

Функция ИмяЭлементаФормы(Источник)

	СтруктураПроверки = Новый Структура("Имя", "");
	ЗаполнитьЗначенияСвойств(СтруктураПроверки, Источник);

	Если Не ЗначениеЗаполнено(СтруктураПроверки.Имя) Тогда
		ВызватьИсключение СтрШаблон(НСтр(
			"ru = 'Не удалось определить оформляемый элемент. Ожидалась строка или элемент формы со свойством ""Имя"", получено: %1'",
			"ru"), Строка(ТипЗнч(Источник)));
	КонецЕсли;

	Возврат СтруктураПроверки.Имя;

КонецФункции

Функция АдаптерПоля(Поле)

	Если ТипЗнч(Поле) = Тип("Строка") Тогда
		Возврат СокрЛП(Поле);
	КонецЕсли;

	СтруктураПроверки = Новый Структура("ПутьКДанным", "");
	ЗаполнитьЗначенияСвойств(СтруктураПроверки, Поле);

	Если Не ЗначениеЗаполнено(СтруктураПроверки.ПутьКДанным) Тогда
		ВызватьИсключение СтрШаблон(НСтр(
			"ru = 'Не удалось определить поле отбора. Ожидалась строка или элемент формы со свойством ""ПутьКДанным"", получено: %1'",
			"ru"), Строка(ТипЗнч(Поле)));
	КонецЕсли;

	Возврат СтруктураПроверки.ПутьКДанным;

КонецФункции

Процедура ПроверкаУсловногоОформления()

	Если УсловноеОформление = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Сначала вызовите метод ""Установить"" и передайте условное оформление формы'", "ru");
	КонецЕсли;

КонецПроцедуры

Процедура ПроверкаЭлемента()

	ПроверкаУсловногоОформления();

	Если ОформляемыйЭлемент = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Сначала вызовите метод ""Элемент""'", "ru");
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ГенерацияКода

Процедура РазобратьОтбор(Результат, Отбор, УровеньТабуляции)

	Для Каждого ЭлементОтбора Из Отбор.Элементы Цикл

		Если Не ЭлементОтбора.Использование Тогда
			Продолжить;
		КонецЕсли;

		Если ТипЗнч(ЭлементОтбора) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда

			Если ЭлементОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ Тогда
				ПредставлениеГруппы = "ГруппаИ";
			ИначеЕсли ЭлементОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли Тогда
				ПредставлениеГруппы = "ГруппаИли";
			Иначе // ГруппаНе
				ПредставлениеГруппы = "ГруппаНе";
			КонецЕсли;

			Результат = Результат + СтрШаблон(ШаблонГруппы(УровеньТабуляции), ПредставлениеГруппы);

			РазобратьОтбор(Результат, ЭлементОтбора, УровеньТабуляции + 1);

			Результат = Результат + ШаблонКонцаГруппы(УровеньТабуляции);

		ИначеЕсли ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда

			Результат = Результат + СтрШаблон(ШаблонЭлементаОтбора(УровеньТабуляции),
				ПредставлениеВидаСравнения(ЭлементОтбора.ВидСравнения),
				Строка(ЭлементОтбора.ЛевоеЗначение),
				ЗначениеВКоде(ЭлементОтбора.ПравоеЗначение));

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

Функция ПредставлениеПолей(Поля)

	Имена = Новый Массив;

	Для Каждого ОформляемоеПоле Из Поля.Элементы Цикл
		Имена.Добавить(Строка(ОформляемоеПоле.Поле));
	КонецЦикла;

	Возврат СтрСоединить(Имена, ", ");

КонецФункции

Функция ПредставлениеВидаСравнения(ВидСравнения)

	Возврат СтрЗаменить(ТРег(Строка(ВидСравнения)), " ", "");

КонецФункции

// Представление значения в виде литерала встроенного языка.
// Для типов, которые нельзя выразить литералом, возвращается заметный плейсхолдер.
//
// Параметры:
//  Значение - Произвольный
//
// Возвращаемое значение:
//  Строка - фрагмент кода
Функция ЗначениеВКоде(Значение)

	ТипЗначения = ТипЗнч(Значение);

	Если ТипЗначения = Тип("Строка") Тогда
		Возврат """" + СтрЗаменить(Значение, """", """""") + """";

	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		Возврат ?(Значение, "Истина", "Ложь");

	ИначеЕсли ТипЗначения = Тип("Число") Тогда
		Возврат Формат(Значение, "ЧГ=0; ЧРД=.; ЧН=0");

	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		Возврат "'" + Формат(Значение, "ДФ=ггггММддЧЧммсс") + "'";

	ИначеЕсли ТипЗначения = Тип("Цвет") Тогда
		Возврат ЗначениеЦвета(Значение);

	ИначеЕсли ТипЗначения = Тип("ГоризонтальноеПоложение") Тогда
		Возврат ЗначениеГоризонтальногоПоложения(Значение);

	КонецЕсли;

	Возврат ПлейсхолдерЗначения();

КонецФункции

// Представление цвета в виде фрагмента кода.
// Имя цвета распознается и на русском, и на английском - в зависимости от того,
// на каком языке платформа вернула представление. Если цвет распознать не удалось
// (не web-цвет, отсутствует в таблице), подставляется цвет по умолчанию.
//
// Параметры:
//  Цвет - Цвет
//
// Возвращаемое значение:
//  Строка - например "WebЦвета.ЛососьСветлый"
Функция ЗначениеЦвета(Цвет)

	Возврат СтрШаблон("WebЦвета.%1", ИдентификаторWebЦвета(Цвет));

КонецФункции

Функция ИдентификаторWebЦвета(Цвет)

	Если Цвет.Вид <> ВидЦвета.WebЦвет Тогда
		Возврат ЦветПоУмолчанию();
	КонецЕсли;

	Представление = Строка(Цвет);

	// Платформа может вернуть как "Лосось светлый (LightSalmon)", так и одно из имен.
	РусскоеИмя = Представление;
	АнглийскоеИмя = "";

	Открывающая = СтрНайти(Представление, "(");

	Если Открывающая <> 0 Тогда

		РусскоеИмя = Сред(Представление, 1, Открывающая - 1);

		Закрывающая = СтрНайти(Представление, ")");

		Если Закрывающая > Открывающая Тогда
			АнглийскоеИмя = Сред(Представление, Открывающая + 1, Закрывающая - Открывающая - 1);
		КонецЕсли;

	КонецЕсли;

	Цвета = WebЦветаПоИмени();

	Идентификатор = Цвета.Получить(КлючЦвета(РусскоеИмя));

	Если Идентификатор = Неопределено Тогда
		Идентификатор = Цвета.Получить(КлючЦвета(АнглийскоеИмя));
	КонецЕсли;

	Возврат ?(Идентификатор = Неопределено, ЦветПоУмолчанию(), Идентификатор);

КонецФункции

Функция ЦветПоУмолчанию()

	Возврат "ЛососьСветлый";

КонецФункции

// Ключ поиска: без пробелов, дефисов и регистра.
// "Лосось светлый", "лосось-светлый" и "LightSalmon" ищутся одинаково надежно.
Функция КлючЦвета(Имя)

	Возврат ВРег(СтрЗаменить(СтрЗаменить(СокрЛП(Имя), " ", ""), "-", ""));

КонецФункции

// Идентификатор встроенного языка из отображаемого имени:
// "Лосось светлый" -> "ЛососьСветлый", "Акварельно-синий" -> "АкварельноСиний".
// Дефисы и пробелы убираются обязательно - иначе получается невалидный код.
Функция ИдентификаторИзИмени(Имя)

	Результат = "";

	Для Каждого Часть Из СтрРазделить(СтрЗаменить(Имя, "-", " "), " ", Ложь) Цикл

		Слово = СокрЛП(Часть);

		Если ЗначениеЗаполнено(Слово) Тогда
			Результат = Результат + ВРег(Лев(Слово, 1)) + Сред(Слово, 2);
		КонецЕсли;

	КонецЦикла;

	Возврат Результат;

КонецФункции

Процедура ДобавитьWebЦвет(РусскоеИмя, АнглийскоеИмя)

	Идентификатор = ИдентификаторИзИмени(РусскоеИмя);

	КэшWebЦветов.Вставить(КлючЦвета(РусскоеИмя), Идентификатор);
	КэшWebЦветов.Вставить(КлючЦвета(АнглийскоеИмя), Идентификатор);

КонецПроцедуры


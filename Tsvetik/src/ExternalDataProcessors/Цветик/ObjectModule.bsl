#Область ОписаниеПеременных

Перем УсловноеОформление;
Перем ОформляемыйЭлемент;
Перем ТекущийЭлемент;

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Устанавливает условное оформление, с которым будет работать объект.
// Вызывается первым в цепочке.
//
// Параметры:
//  НовоеУсловноеОформление - УсловноеОформлениеКомпоновкиДанных - Условное оформление формы.
//
// Возвращаемое значение:
//  ВнешняяОбработкаОбъект.Цветик - Установить
Функция Установить(НовоеУсловноеОформление) Экспорт

	УсловноеОформление = НовоеУсловноеОформление;
	ОформляемыйЭлемент = Неопределено;
	ТекущийЭлемент = Неопределено;

	Возврат ЭтотОбъект;

КонецФункции

// Элемент/ы к которым будет применено условное оформление.
//
// Параметры:
//  Имена - Строка - Имя элемента для которого применяем значение.
//                 Можно передать множество элементов, разделив ",".
//  	- ТаблицаФормы, ПолеФормы, ГруппаФормы - Объект должен содержать свойство "Имя"
//      - Массив Из Строка -
//      - Массив Из ТаблицаФормы, ПолеФормы, ГруппаФормы -
//
// Возвращаемое значение:
//  ВнешняяОбработкаОбъект.Цветик - Элемент
Функция Элемент(Имена) Экспорт

	ПроверкаУсловногоОформления();

	ОформляемыйЭлемент = УсловноеОформление.Элементы.Добавить();
	ТекущийЭлемент = ОформляемыйЭлемент;

	Если ТипЗнч(Имена) = Тип("Массив") Тогда

		Для Каждого Имя Из Имена Цикл
			ДобавитьОформляемоеПоле(Имя);
		КонецЦикла;

	Иначе
		ДобавитьОформляемоеПоле(Имена);
	КонецЕсли;

	Возврат ЭтотОбъект;

КонецФункции

// Очищает условное оформление.
//
// Возвращаемое значение:
//  ВнешняяОбработкаОбъект.Цветик - Очистить
Функция Очистить() Экспорт

	ПроверкаУсловногоОформления();

	УсловноеОформление.Элементы.Очистить();

	ОформляемыйЭлемент = Неопределено;
	ТекущийЭлемент = Неопределено;

	Возврат ЭтотОбъект;

КонецФункции

// Оформление.
//
// Параметры:
//  Свойство - Строка - "ОтметкаНезаполненного",
//  Значение - Произвольный -
//
// Возвращаемое значение:
//  ВнешняяОбработкаОбъект.Цветик - Оформление
Функция Оформление(Свойство, Значение) Экспорт

	ПроверкаЭлемента();

	ОформляемыйЭлемент.Оформление.УстановитьЗначениеПараметра(Свойство, Значение);

	Возврат ЭтотОбъект;

КонецФункции

// Генерирует код, который можно копипастить к себе, на основании переданного в объект условного оформления
//
// Возвращаемое значение:
//  Строка - готовый код
Функция СгенерироватьКод() Экспорт

	ПроверкаУсловногоОформления();

	БазоваяТабуляция = 1;

	Результат = "Цветик.Установить(УсловноеОформление)";
	Результат = Результат + Символы.ПС + Табуляция(БазоваяТабуляция) + ".Очистить()";

	ШаблонЭлемента = Символы.ПС + Табуляция(БазоваяТабуляция) + ".Элемент(""%1"")";
	ШаблонОформления = Символы.ПС + Табуляция(БазоваяТабуляция + 1) + ".Оформление(""%1"", %2)";

	Для Каждого ЭлементОформления Из УсловноеОформление.Элементы Цикл

		Если Не ЭлементОформления.Использование Тогда
			Продолжить;
		КонецЕсли;

		Результат = Результат + СтрШаблон(ШаблонЭлемента, ПредставлениеПолей(ЭлементОформления.Поля));

		РазобратьОтбор(Результат, ЭлементОформления.Отбор, БазоваяТабуляция + 1);

		Для Каждого ЗначениеОформления Из ЭлементОформления.Оформление.Элементы Цикл

			Если Не ЗначениеОформления.Использование Тогда
				Продолжить;
			КонецЕсли;

			Результат = Результат + СтрШаблон(ШаблонОформления, Строка(ЗначениеОформления.Параметр),
				ЗначениеВКоде(ЗначениеОформления.Значение));
		КонецЦикла;

	КонецЦикла;

	Возврат Результат + ";";

КонецФункции


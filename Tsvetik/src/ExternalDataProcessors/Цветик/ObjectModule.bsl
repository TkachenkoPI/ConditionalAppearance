// Завершает текущую группу. Функция нужна для сложных условий, в которых нужно возвращаться к родительским группам.
//    Например. Нужна ГруппаИ, внутри которой есть ГруппаИли и ГруппаИ.
//
//    Цветик.Установить(УсловноеОформление)
//		.Очистить()
//		.Элемент("Реквизит2")
//			.ГруппаИ()
//				.ГруппаИли()
//					.Равно("Реквизит3", Истина)
//					.НачинаетсяС("Реквизит4", "я")
//				.КонецГруппы()
//				.ГруппаИ()
//					.Равно("Реквизит1", Истина)
//					.НачинаетсяС("Реквизит2", Истина)
//				.КонецГруппы()
//			.КонецГруппы()
//
//
// Возвращаемое значение:
//  ВнешняяОбработкаОбъект.Цветик - Конец группы
Функция КонецГруппы() Экспорт

	ПроверкаЭлемента();

	Если ТипЗнч(ТекущийЭлемент) <> Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда
		ВызватьИсключение НСтр("ru = 'Вызов метода ""КонецГруппы"" без открытой группы отбора'", "ru");
	КонецЕсли;

	Родитель = ТекущийЭлемент.Родитель;

	Если ТипЗнч(Родитель) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда
		ТекущийЭлемент = Родитель;
	Иначе
		ТекущийЭлемент = ОформляемыйЭлемент;
	КонецЕсли;

	Возврат ЭтотОбъект;

КонецФункции


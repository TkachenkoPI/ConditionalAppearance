// Прогоняет весь программный интерфейс Цветика на данных этой формы:
// все виды сравнения, все типы групп, все способы передачи элементов и все методы оформления.
// В Результат кладется сгенерированный код - так заодно проверяется и СгенерироватьКод().
//
// Цвета заданы через Новый Цвет(R, G, B) везде, кроме трех web-цветов, проверенных в Тест1-8:
// имена свойств WebЦвета зависят от языка интерфейса, и промах дает
// "Поле объекта не обнаружено" уже во время выполнения. Обратная сторона: для не-web-цветов
// СгенерироватьКод() выводит _ПодставьтеЗначение_ - это ожидаемое поведение генератора.
&НаСервере
Procedure МегаТестAtServer()

	ПодготовитьДанныеМегаТеста();

	Цветик = НовыйЦветик().Очистить();

	// 1. Строковые сравнения. Все условия истинны для "яблоко" - элемент должен раскраситься.
	//    Заодно: ЦветФона, ЦветТекста, Шрифт.
	Цветик
		.Элемент(Элементы.Реквизит1)
			.ГруппаИ()
				.Заполнено(Элементы.Реквизит1)
				.Содержит(Элементы.Реквизит1, "блок")
				.НеСодержит(Элементы.Реквизит1, "груша")
				.НачинаетсяС(Элементы.Реквизит1, "я")
				.НеНачинаетсяС(Элементы.Реквизит1, "г")
				.Подобно(Элементы.Реквизит1, "я%")
				.НеПодобно(Элементы.Реквизит1, "г%")
			.КонецГруппы()
			.ЦветФона(WebЦвета.ЛососьСветлый)
			.ЦветТекста(Новый Цвет(0, 0, 139))
			.Шрифт(Новый Шрифт(, , Истина));

	// 2. Числовые сравнения. Все условия истинны для 42.
	//    Заодно: ГоризонтальноеПоложение, ВыделятьОтрицательные, Формат через Оформление().
	Цветик
		.Элемент(Элементы.Реквизит2)
			.ГруппаИ()
				.НеРавно(Элементы.Реквизит2, 0)
				.Больше(Элементы.Реквизит2, 0)
				.БольшеИлиРавно(Элементы.Реквизит2, 42)
				.Меньше(Элементы.Реквизит2, 100)
				.МеньшеИлиРавно(Элементы.Реквизит2, 42)
			.КонецГруппы()
			.ГоризонтальноеПоложение(ГоризонтальноеПоложение.Право)
			.ВыделятьОтрицательные(Истина)
			.Оформление("Формат", "ЧЦ=10; ЧДЦ=2");

	// 3. Списочные сравнения. Отбор без явной группы - неявная ГруппаИ.
	Цветик
		.Элемент(Элементы.Реквизит5)
			.ВСписке(Элементы.Реквизит2, СписокДопустимых())
			.НеВСписке(Элементы.Реквизит2, СписокЗапрещенных())
			.ЦветТекста(Новый Цвет(0, 128, 0));

	// 4. Вложенные группы: И( Равно, ИЛИ(...), НЕ(...) ) с возвратом через КонецГруппы.
	Цветик
		.Элемент(Элементы.Реквизит3)
			.ГруппаИ()
				.Равно(Элементы.Реквизит3, Истина)
				.ГруппаИли()
					.Равно(Элементы.Реквизит4, Истина)
					.Равно(Элементы.Реквизит2, 42)
				.КонецГруппы()
				.ГруппаНе()
					.Равно(Элементы.Реквизит4, Истина)
				.КонецГруппы()
			.КонецГруппы()
			.ЦветФона(WebЦвета.Золотой);

	// 5. Передача элементов строкой со списком имен.
	Цветик
		.Элемент("Реквизит1,Реквизит2, Реквизит5")
			.Равно(Элементы.Реквизит3, Истина)
			.Оформление("ЦветТекста", Новый Цвет(139, 0, 0));

	// 6. Передача элементов массивом: строка, поле формы и таблица формы вперемешку.
	МассивЭлементов = Новый Массив;
	МассивЭлементов.Добавить("Реквизит4");
	МассивЭлементов.Добавить(Элементы.Реквизит3);
	МассивЭлементов.Добавить(Элементы.Состав);

	Цветик
		.Элемент(МассивЭлементов)
			.Равно(Элементы.Реквизит2, 42)
			.ЦветФона(Новый Цвет(245, 245, 245));

	// 7. Оформление строк таблицы по значению колонки. ТолькоПросмотр и Доступность.
	Цветик
		.Элемент(Элементы.Состав)
			.Равно(Элементы.СоставРеквизит3, Истина)
			.ЦветФона(WebЦвета.Аквамарин)
			.ТолькоПросмотр(Истина);

	Цветик
		.Элемент(Элементы.СоставРеквизит2)
			.Меньше(Элементы.СоставРеквизит2, 0)
			.Доступность(Ложь)
			.ЦветТекста(Новый Цвет(255, 0, 0));

	// 8. Подмена текста и отметка незаполненного на пустых ячейках.
	Цветик
		.Элемент(Элементы.СоставРеквизит1)
			.НеЗаполнено(Элементы.СоставРеквизит1)
			.Текст("<не задано>")
			.ОтметкаНезаполненного(Истина);

	// 9. Видимость и Отображать задаются парой: первое прячет элемент, второе - вывод значения.
	Цветик
		.Элемент(Элементы.СоставРеквизит4)
			.ГруппаНе()
				.Равно(Элементы.СоставРеквизит3, Истина)
			.КонецГруппы()
			.Видимость(Ложь)
			.Отображать(Ложь);

	// Иерархические сравнения (ВИерархии, НеВИерархии, ВСпискеПоИерархии, НеВСпискеПоИерархии)
	// здесь не проверяются: им нужно ссылочное поле с иерархией, а на этой форме
	// только примитивные типы. Проверять их надо на форме со справочником:
	//
	//	.Элемент(Элементы.Номенклатура)
	//		.ВИерархии(Элементы.Номенклатура, ГруппаНоменклатуры)
	//		.ЦветФона(WebЦвета.ЛососьСветлый);

	Результат = Цветик.СгенерироватьКод();

EndProcedure

// Заполняет реквизиты формы значениями, на которых отборы мегатеста срабатывают.
&НаСервере
Процедура ПодготовитьДанныеМегаТеста()

	Реквизит1 = "яблоко";
	Реквизит2 = 42;
	Реквизит3 = Истина;
	Реквизит4 = Ложь;

	Реквизит5.Очистить();
	Реквизит5.Добавить(1, "Первый");
	Реквизит5.Добавить(2, "Второй");

	Состав.Очистить();

	НоваяСтрока = Состав.Добавить();
	НоваяСтрока.Реквизит1 = "строка 1";
	НоваяСтрока.Реквизит2 = 10;
	НоваяСтрока.Реквизит3 = Истина;
	НоваяСтрока.Реквизит4 = Истина;

	НоваяСтрока = Состав.Добавить();
	НоваяСтрока.Реквизит1 = "";
	НоваяСтрока.Реквизит2 = -5;
	НоваяСтрока.Реквизит3 = Ложь;
	НоваяСтрока.Реквизит4 = Ложь;

	НоваяСтрока = Состав.Добавить();
	НоваяСтрока.Реквизит1 = "строка 3";
	НоваяСтрока.Реквизит2 = 0;
	НоваяСтрока.Реквизит3 = Истина;
	НоваяСтрока.Реквизит4 = Ложь;

	НоваяСтрока = Состав.Добавить();
	НоваяСтрока.Реквизит1 = "";
	НоваяСтрока.Реквизит2 = -100;
	НоваяСтрока.Реквизит3 = Ложь;
	НоваяСтрока.Реквизит4 = Истина;

КонецПроцедуры


// Два сценария сокрытия:
//  1. Реквизит3 (реквизит формы) = Истина -> прячем Реквизит1 и колонку Состав.Реквизит2 целиком.
//  2. Реквизит3 строки таблицы = Истина -> в этой строке подменяем текст Реквизит1 на "***".
//
// Второй сценарий - именно подмена текста, а не сокрытие: значение в данных остается,
// меняется только то, что видно в ячейке.
&AtServer
Procedure ТестВидимостиAtServer()

	ПодготовитьДанныеТестаВидимости();

	// ЭТОТ БЛОК НИЧЕГО НЕ ДЕЛАЕТ И ОСТАВЛЕН КАК ДЕМОНСТРАЦИЯ ОГРАНИЧЕНИЯ.
	// Реквизит1 - обычное поле формы, а не элемент таблицы. Условное оформление
	// применяет Видимость и Отображать только к колонкам таблицы и к самой таблице,
	// поэтому отбор отрабатывает, а поле остается видимым. Исключения при этом нет.
	// Обычное поле прячется только кодом: Элементы.Реквизит1.Видимость = Не Реквизит3;
	НовыйЦветик()
		.Очистить()
		.Элемент(Элементы.Реквизит1)
			.Равно(Элементы.Реквизит3, Истина)
			.Видимость(Ложь)
			.Отображать(Ложь);

	НовыйЦветик()
		.Элемент(Элементы.СоставРеквизит2)
			.Равно(Элементы.Реквизит3, Истина)
			.Видимость(Ложь)
			.Отображать(Ложь);

	НовыйЦветик()
		.Элемент(Элементы.СоставРеквизит1)
			.Равно(Элементы.СоставРеквизит3, Истина)
			.Текст("***");

	Результат = "Цветик.Установить(УсловноеОформление)
	|	.Очистить()
	|	.Элемент(Элементы.Реквизит1)
	|		.Равно(Элементы.Реквизит3, Истина)
	|		.Видимость(Ложь)
	|		.Отображать(Ложь);
	|
	|Цветик.Установить(УсловноеОформление)
	|	.Элемент(Элементы.СоставРеквизит2)
	|		.Равно(Элементы.Реквизит3, Истина)
	|		.Видимость(Ложь)
	|		.Отображать(Ложь);
	|
	|Цветик.Установить(УсловноеОформление)
	|	.Элемент(Элементы.СоставРеквизит1)
	|		.Равно(Элементы.СоставРеквизит3, Истина)
	|		.Текст(""***"");";

EndProcedure

